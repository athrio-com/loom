{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "exactOptionalPropertyTypes": false,
    "lib": ["ESNext"],
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun", "node"]
  },
  "include": [
    "src/vite.ts",
    "build.ts",
    "src/store.ts",
    "src/api.ts",
    "src/mcp.ts",
    "src/serve.ts"
  ]
}
