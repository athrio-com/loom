{
  "name": "loom-vscode",
  "publisher": "athrio",
  "displayName": "Loom",
  "description": "A VS Code extension for Loom",
  "version": "0.0.6",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/athrio-com/loom.git",
    "directory": "packages/loom-vscode"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "activationEvents": [
    "onLanguage:loom"
  ],
  "main": "./dist/client.js",
  "contributes": {
    "languages": [
      {
        "id": "loom",
        "extensions": [
          ".loom"
        ]
      }
    ]
  },
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch",
    "pack:vsix": "vite build && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@volar/language-server": "^2.4.28",
    "@volar/vscode": "^2.4.28",
    "vscode-languageclient": "^9.0.1"
  }
}
