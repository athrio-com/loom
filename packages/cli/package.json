{
  "name": "@loom/cli",
  "version": "0.1.0",
  "description": "Tangle Loom literate sources into real source files.",
  "license": "Apache-2.0 OR MIT",
  "type": "module",
  "bin": {
    "loom": "dist/main.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/athrio-com/loom.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsx src/main.ts tangle corpus && vite build",
    "prepack": "vite build"
  },
  "devDependencies": {
    "@loom/language-server": "workspace:*",
    "@effect/platform-node": "^0.106.0",
    "effect": "3.21.2",
    "tsx": "^4.22.0",
    "vite": "^8.0.12"
  }
}
