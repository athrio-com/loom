{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@literate/core": ["./src/core.ts"]
    }
  },
  "include": [
    "src/**/*",
    "corpus",
    "*.ts",
    "packages/loom-lang/src/ast/index.ts",
    "packages/loom-lang/src/ast/LineRanges.ts",
    "packages/loom-lang/src/ast/Weft.test.ts",
    "packages/loom-lang/src/ast/LineRanges.test.ts",
    "packages/loom-lang/src/ast/Weft.ts",
    "packages/loom-lang/src/ast/LoomWeftsStream.ts",
    "packages/loom-lang/src/ast/LoomAst.ts"
  ]
}
