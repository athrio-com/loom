{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "noEmit": true,
    "types": [
      "bun"
    ],
    "paths": {
      "@literate/core": [
        "./src/core.ts"
      ]
    }
  },
  "include": [
    "src/**/*",
    "corpus",
    "*.ts"
  ]
}
