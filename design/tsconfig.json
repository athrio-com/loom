{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "target": "es2022",
    "lib": ["es2023", "dom", "dom.iterable"],
    "types": ["bun"],
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["src/server.ts", "src/browser-globals.ts"]
}
