{
  "name": "loom",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=26",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "pnpm -r build",
    "watch": "pnpm -r --parallel watch",
    "pack:vsix": "pnpm --filter loom-vscode run pack:vsix",
    "loom": "node packages/loom-cli/dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.93",
    "effect": "4.0.0-beta.93"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.93",
    "@types/node": "^25.9.3",
    "@volar/kit": "^2.4.28",
    "@volar/language-core": "^2.4.28",
    "@volar/language-server": "^2.4.28",
    "@volar/typescript": "^2.4.28",
    "@vscode/vsce": "^3.9.2",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "volar-service-typescript": "^0.0.71"
  }
}
