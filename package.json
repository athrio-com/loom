{
  "name": "loom",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.2.20",
  "engines": {
    "bun": ">=1.2"
  },
  "workspaces": [
    "packages/*",
    "foldkit/packages/*",
    "site",
    "design"
  ],
  "trustedDependencies": [
    "@parcel/watcher",
    "@vscode/vsce-sign",
    "esbuild",
    "keytar",
    "msgpackr-extract"
  ],
  "scripts": {
    "build": "bun run --filter './packages/*' --filter './site' build",
    "watch": "bun run --filter './packages/*' watch",
    "pack:vsix": "bun run --filter loom-vscode pack:vsix",
    "loom": "bun packages/loom/dist/main.js",
    "bump": "bun scripts/bump.ts",
    "release": "bun scripts/release.ts",
    "catalog": "bun run --filter loom-design-catalog dev",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.93",
    "effect": "4.0.0-beta.93"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@volar/kit": "^2.4.28",
    "@volar/language-core": "^2.4.28",
    "@volar/language-server": "^2.4.28",
    "@volar/typescript": "^2.4.28",
    "@vscode/vsce": "^3.9.2",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "volar-service-typescript": "^0.0.71"
  }
}
